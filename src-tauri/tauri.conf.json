{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "engram-dashboard",
  "version": "0.1.0",
  "identifier": "com.engram.dashboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Engram Dashboard",
        "width": 1280,
        "height": 800
      },
      {
        "label": "agent-tree",
        "url": "index.html#/tree",
        "visible": false,
        "width": 280,
        "height": 600,
        "decorations": true,
        "title": "Agent Tree"
      },
      {
        "label": "slot-popup",
        "url": "index.html#/popup",
        "visible": false,
        "width": 800,
        "height": 600,
        "decorations": true,
        "title": "Slot Popup"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
